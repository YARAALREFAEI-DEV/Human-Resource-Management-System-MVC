<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>HumanResources Management System</title>
    <link rel="stylesheet" href="~/humanresources-master/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

</head>
<body>

    <div class="js-animsition animsition" id="site-wrap" data-animsition-in-class="fade-in" data-animsition-out-class="fade-out">

        <header class="templateux-navbar" role="banner">

            <div class="container" data-aos="fade-down">
                <div class="row">

                    <div class="col-3 templateux-logo">
                        <a>HumanResources</a>
                    </div>
                    <nav class="col-9 site-nav">
                        <button class="d-block d-md-none hamburger hamburger--spin templateux-toggle templateux-toggle-light ml-auto templateux-toggle-menu" data-toggle="collapse" data-target="#mobile-menu" aria-controls="mobile-menu" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="hamburger-box">
                                <span class="hamburger-inner"></span>
                            </span>
                        </button> 

                        <ul class="sf-menu templateux-menu d-none d-md-block">
                            <li class="active">
                                <a asp-action="Index" asp-controller="Home" class="animsition-link">Home</a>
                            </li>

                            <li><a asp-action="Login" asp-controller="Account" class="animsition-link">Login</a></li>
                        </ul> 

                    </nav>
                </div> 
            </div> 
        </header> 

        <div class="templateux-cover" style="background-image: url(/humanresources-master/images/hero_1.jpg);">
            <div class="container">
                <div class="row align-items-lg-center">

                    <div class="col-lg-6 order-lg-1">
                        <h1 class="heading mb-3 text-white" data-aos="fade-up">We Are Your Partners in <strong>Human Resource</strong></h1>
                    </div>

                </div>
            </div>
        </div> 
        <br />
        <br />
        <br />
        <div class="container">
            @RenderBody()
        </div>

        <br />
        <br />
        <br />
        <br />
        <div class="templateux-section pt-0 pb-0">
            <div class="container">
                <div class="row">
                    <div class="col-md-12 templateux-overlap">
                        <div class="row">
                            <div class="col-md-4" data-aos="fade-up" data-aos-delay="600">
                                <div class="media block-icon-1 d-block text-left">
                                    <div class="icon mb-3">
                                        <img src="~/humanresources-master/images/flaticon/svg/001-consultation.svg" alt="Image" class="img-fluid">
                                    </div>
                                    <div class="media-body">
                                        <h3 class="h5 mb-4">Corporate Collaboration</h3>
                                        <p><a href="#">Learn More</a></p>
                                    </div>
                                </div> <!-- .block-icon-1 -->
                            </div>
                            <div class="col-md-4" data-aos="fade-up" data-aos-delay="700">
                                <div class="media block-icon-1 d-block text-left">
                                    <div class="icon mb-3">
                                        <img src="~/humanresources-master/images/flaticon/svg/002-discussion.svg" alt="Image" class="img-fluid">
                                    </div>
                                    <div class="media-body">
                                        <h3 class="h5 mb-4">Strategic Partners</h3>
                                        <p><a href="#">Learn More</a></p>
                                    </div>
                                </div> <!-- .block-icon-1 -->
                            </div>
                            <div class="col-md-4" data-aos="fade-up" data-aos-delay="800">
                                <div class="media block-icon-1 d-block text-left">
                                    <div class="icon mb-3">
                                        <img src="~/humanresources-master/images/flaticon/svg/003-turnover.svg" alt="Image" class="img-fluid">
                                    </div>
                                    <div class="media-body">
                                        <h3 class="h5 mb-4">Infinite Posibilities</h3>
                                        <p><a href="#">Learn More</a></p>
                                    </div>
                                </div> <!-- .block-icon-1 -->
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div> <!-- .templateux-section -->


        <br />
        <br />


        <footer class="templateux-footer bg-light">
            <div class="container text-center">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h3>About Us</h3>
                        <p>Your trusted partner in human resources management.</p>
                    </div>
                    <div class="col-md-6">
                        <h3>Connect</h3>
                        <ul class="list-unstyled block-social">
                            <li><a href="#" class="p-1"><span class="icon-facebook-square"></span></a></li>
                            <li><a href="#" class="p-1"><span class="icon-twitter"></span></a></li>
                            <li><a href="#" class="p-1"><span class="icon-linkedin"></span></a></li>
                        </ul>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <p>
                            &copy;<script>document.write(new Date().getFullYear());</script> All rights reserved |
                        </p>
                    </div>
                </div>
            </div>
        </footer>


        <script src="~/humanresources-master/js/scripts-all.js"></script>
        <script src="~/humanresources-master/js/main.js"></script>

</body>
</html>