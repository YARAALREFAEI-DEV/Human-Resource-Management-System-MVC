@model HRMS_FinalProject.Models.LeaveType

@{
    ViewData["Title"] = "Edit Leave Type";
    Layout = "~/Areas/Admin/Views/Shared/partial_Layout.cshtml";
}
<br />
<br />
<div class="container mt-5">
    <h1 class="text-center">Edit Leave Type</h1>

    <div class="row justify-content-center mt-4">
        <div class="col-md-6">
            <h4 class="text-center">Update Leave Type Information</h4>
            <hr />
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger text-center"></div>

                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="LeaveTypeName" class="form-label"></label>
                    <input asp-for="LeaveTypeName" class="form-control" />
                    <span asp-validation-for="LeaveTypeName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CreatedAt" class="form-label"></label>
                    <input asp-for="CreatedAt" class="form-control" type="date" />
                    <span asp-validation-for="CreatedAt" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="DefaultAvailableDays" class="form-label"></label>
                    <input asp-for="DefaultAvailableDays" class="form-control" type="number" min="0" />
                    <span asp-validation-for="DefaultAvailableDays" class="text-danger"></span>
                </div>

                <div class="form-group text-center mt-4">
                    <input type="submit" value="Save" class="btn btn-primary btn-lg px-4" />
                </div>
            </form>
        </div>
    </div>

    <div class="text-center mt-3">
        <a asp-action="Index" class="btn btn-white">Back to List</a>
    </div>
</div>
