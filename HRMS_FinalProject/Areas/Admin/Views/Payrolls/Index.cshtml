@model IEnumerable<HRMS_FinalProject.Models.Payroll>

@{
    ViewData["Title"] = "Payroll Index";
    Layout = "~/Areas/Admin/Views/Shared/partial_Layout.cshtml";
}
<br />
<br />
<br />
<div class="container mt-5">
    <h1 class="text-center">Payroll Index</h1>

    <div class="mb-3 text-center">
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="thead-white">
            <tr>
                <th class="text-end pe-8">
                    @Html.DisplayNameFor(model => model.First().PayrollDate)
                </th>
                <th class="text-end pe-8">
                    @Html.DisplayNameFor(model => model.First().GrossSalary)
                </th>
                <th class="text-end pe-8">
                    @Html.DisplayNameFor(model => model.First().NetSalary)
                </th>
                <th class="text-end pe-8">
                    @Html.DisplayNameFor(model => model.First().increment)
                </th>
                <th class="text-end pe-8">
                    @Html.DisplayNameFor(model => model.First().incrementType)
                </th>
                <th class="text-end pe-8">
                    @Html.DisplayNameFor(model => model.First().Employee.FullName)
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.PayrollDate)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.GrossSalary)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.NetSalary)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.increment)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.incrementType)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Employee.FullName)
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.PayrollId">Edit</a> |
                            <a asp-action="Details" asp-route-id="@item.PayrollId">Details</a> |
                            <a asp-action="Delete" asp-route-id="@item.PayrollId">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">No payroll records found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
