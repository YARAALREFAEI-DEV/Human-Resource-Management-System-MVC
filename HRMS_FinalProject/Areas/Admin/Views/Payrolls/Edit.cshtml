@model HRMS_FinalProject.Models.Payroll

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Areas/Admin/Views/Shared/partial_reg_Layout.cshtml";

}

<h1>Edit</h1>

<h4>Payroll</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="PayrollId" />
            <div class="form-group">
                <label asp-for="EmployeeID" class="control-label"></label>
                <select asp-for="EmployeeID" class="form-control" asp-items="ViewBag.EmployeeID"></select>
                <span asp-validation-for="EmployeeID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PayrollDate" class="control-label"></label>
                <input asp-for="PayrollDate" class="form-control" />
                <span asp-validation-for="PayrollDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GrossSalary" class="control-label"></label>
                <input asp-for="GrossSalary" class="form-control" />
                <span asp-validation-for="GrossSalary" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NetSalary" class="control-label"></label>
                <input asp-for="NetSalary" class="form-control" />
                <span asp-validation-for="NetSalary" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="increment" class="control-label"></label>
                <input asp-for="increment" class="form-control" />
                <span asp-validation-for="increment" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="incrementType" class="control-label"></label>
                <select asp-for="incrementType" class="form-control" asp-items="ViewBag.IncrementType">
                    <option value="">Select Increment Type</option>
                </select>
                <span asp-validation-for="incrementType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

