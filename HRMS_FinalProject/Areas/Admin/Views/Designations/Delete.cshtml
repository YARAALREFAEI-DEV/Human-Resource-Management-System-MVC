@model HRMS_FinalProject.Models.Designation

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Areas/Admin/Views/Shared/partial_Layout.cshtml";
}

<br />
<br />
<div class="container mt-5">
    <h3 class="text-center">Are you sure you want to delete this?</h3>
    <hr />

    <div>
        <h4 class="text-center">Designation Details</h4>
        <dl class="row">
            <dt class="col-sm-4">
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Title)
            </dd>

            <dt class="col-sm-4">
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Department.DepartmentTitle)
            </dd>
        </dl>
    </div>

    <div class="text-center mt-4">
        <form asp-action="Delete">
            <input type="hidden" asp-for="DesignationID" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-primary">Back to List</a>
        </form>
    </div>
</div>
