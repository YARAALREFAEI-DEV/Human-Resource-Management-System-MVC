@model HRMS_FinalProject.Models.Department

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Areas/Admin/Views/Shared/partial_Layout.cshtml";

}

<div class="container">
    <h1 class="text-center">Edit</h1>
    <h4 class="text-center">Department</h4>
    <hr />

    <div class="row justify-content-center">
        <div class="col-md-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="DepartmentID" />
                <div class="form-group">
                    <label asp-for="DepartmentTitle" class="control-label"></label>
                    <input asp-for="DepartmentTitle" class="form-control" />
                    <span asp-validation-for="DepartmentTitle" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Description" class="control-label"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DepartmentManagerID" class="form-label">Department Manager</label>
                    <select asp-for="DepartmentManagerID" class="form-select" asp-items="ViewBag.Employees">
                        <option value="">-- Select Manager --</option>
                    </select>
                    <span asp-validation-for="DepartmentManagerID" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input type="submit" value="Save" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <div class="text-center">
        <a asp-action="Index">Back to List</a>
    </div>
</div>