@model HRMS_FinalProject.Models.Department

@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/Admin/Views/Shared/partial_Layout.cshtml";
}

<div class="container" style="margin-left: 250px; padding-top: 20px;">
    <h1>Create New Department</h1>

    <h4>Department Details</h4>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Department Title -->
                <div class="form-group mb-3">
                    <label asp-for="DepartmentTitle" class="form-label"></label>
                    <input asp-for="DepartmentTitle" class="form-control" placeholder="Enter department title" />
                    <span asp-validation-for="DepartmentTitle" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Department Manager Dropdown -->
                <div class="form-group mb-3">
                    <label asp-for="DepartmentManagerID" class="form-label">Department Manager</label>
                    <select asp-for="DepartmentManagerID" class="form-select" asp-items="ViewBag.Employees">
                        <option value="">-- Select Manager --</option>
                    </select>
                    <span asp-validation-for="DepartmentManagerID" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index">Back to List</a>
    </div>
</div>
