@model HRMS_FinalProject.Models.Department

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Areas/Admin/Views/Shared/partial_Layout.cshtml";
}

<br />
<br />
<br />

<div class="container d-flex flex-column justify-content-center align-items-center vh-100">
    <h1></h1>

    <h3>Are you sure you want to delete this Department?</h3>
    <div class="text-center">
        <hr />
        <dl class="row justify-content-center">
            <dt class="col-sm-2">
                <br /> 
                @Html.DisplayNameFor(model => model.DepartmentTitle)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.DepartmentTitle)
            </dd>
            <dt class="col-sm-2">
                <br /> 
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Description)
            </dd>
        </dl>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="DepartmentID" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-primary">Back to List</a>
        </form>
    </div>
</div>
