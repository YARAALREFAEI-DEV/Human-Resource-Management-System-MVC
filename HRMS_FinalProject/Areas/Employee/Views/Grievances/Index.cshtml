@model IEnumerable<HRMS_FinalProject.Models.Grievance>

@{
    ViewData["Title"] = "Grievances Index";
    Layout = "~/Areas/Employee/Views/Shared/partial_layout.cshtml";
}
<br />
<br />
<br />
<div class="container mt-5">
    <h1 class="text-center">My Grievances</h1>

    <p class="text-center">
        <a class="btn btn-primary" asp-action="Create">Create New</a>
    </p>

    <table class="table table-striped table-bordered">
        <thead class="thead-white">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Description)</th>
                <th>@Html.DisplayNameFor(model => model.SubmissionDate)</th>
                <th>@Html.DisplayNameFor(model => model.Status)</th>
                <th>@Html.DisplayNameFor(model => model.employee.FullName)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center">No grievances found.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Description)</td>
                        <td>@Html.DisplayFor(modelItem => item.SubmissionDate)</td>
                        <td>@Html.DisplayFor(modelItem => item.Status)</td>
                        <td>@Html.DisplayFor(modelItem => item.employee.FullName)</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.GrievanceId">Details</a> |
                            <a asp-action="Delete" asp-route-id="@item.GrievanceId" onclick="return confirm('Are you sure you want to delete this grievance?');">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
