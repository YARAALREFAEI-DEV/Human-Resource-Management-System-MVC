@model HRMS_FinalProject.Models.Resignation

@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/Employee/Views/Shared/partial_reg_layout.cshtml";
}

<div class="container mt-5">
    <h1>Create Resignation</h1>
    <h4>Submit Your Resignation</h4>
    <hr />

    <div class="row">
        <div class="col-md-6 offset-md-3">
            <form asp-action="Create">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

              

                <div class="form-group">
                    <label asp-for="ResignationDate" class="control-label"></label>
                    <input asp-for="ResignationDate" class="form-control" type="date" />
                    <span asp-validation-for="ResignationDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Reason" class="control-label"></label>
                    <textarea asp-for="Reason" class="form-control" rows="3" placeholder="Enter the reason for resignation"></textarea>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Status" class="control-label"></label>
                    <input asp-for="Status" class="form-control" value="Pending" readonly />
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary btn-block" />
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" class="btn btn-link">Back to List</a>
    </div>
</div>
