@model IEnumerable<HRMS_FinalProject.Models.Payroll>

@{
    ViewData["Title"] = "Payroll Index";
    Layout = "~/Areas/Employee/Views/Shared/partial_Layout.cshtml";
}
<br />
<br />
<br />
<div class="container mt-5">
    <h1 class="text-center">Your Payroll Records</h1>

    <table class="table table-striped table-bordered">
        <thead class="thead-white">
            <tr>
                <th class="text-end pe-8">Payroll Date</th>
                <th class="text-end pe-8">Gross Salary</th>
                <th class="text-end pe-8">Net Salary</th>
                <th class="text-end pe-8">Increment</th>
                <th class="text-end pe-8">Increment Type</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.PayrollDate)</td>
                        <td>@Html.DisplayFor(modelItem => item.GrossSalary)</td>
                        <td>@Html.DisplayFor(modelItem => item.NetSalary)</td>
                        <td>@Html.DisplayFor(modelItem => item.increment)</td>
                        <td>@Html.DisplayFor(modelItem => item.incrementType)</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.PayrollId">Details</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No payroll records found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
